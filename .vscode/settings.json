{
  "workbench.colorCustomizations": {
    "titleBar.activeBackground": "#cc6600",
    "titleBar.activeForeground": "#ffffff",
    "titleBar.inactiveBackground": "#994400",
    "titleBar.inactiveForeground": "#cfcfcf"
  },
  "window.title": "${folderName} — ${activeEditorShort} — ${rootPath}",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "chat.tools.terminal.autoApprove": {
    "Test-Path": true,
    "Test-ModuleManifest": true,
    "Invoke-Pester": true,
    "Invoke-Linter": true,
    "/Get-Content.*perfource-commander-console/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^# Re-save Render\\.psm1 with UTF-8 BOM so unicode renders correctly\n\\$path = 'C:\\\\Users\\\\lpensjo\\\\src\\\\perfource-commander-console\\\\tui\\\\Render\\.psm1'\n\\$content = \\[System\\.IO\\.File\\]::ReadAllText\\(\\$path, \\[System\\.Text\\.Encoding\\]::UTF8\\)\n\\$utf8Bom = New-Object System\\.Text\\.UTF8Encoding\\(\\$true\\)\n\\[System\\.IO\\.File\\]::WriteAllText\\(\\$path, \\$content, \\$utf8Bom\\)\n\\$bytes = \\[System\\.IO\\.File\\]::ReadAllBytes\\(\\$path\\)\n\"BOM bytes: \\$\\(\\$bytes\\[0\\]\\) \\$\\(\\$bytes\\[1\\]\\) \\$\\(\\$bytes\\[2\\]\\)\"\n$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "Remove-Module": true,
    "Import-Module": true,
    "Get-Command": true,
    "/^pwsh -NoProfile -Command \"Import-Module Pester -Force; Invoke-Pester -Path tests\\\\\"$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^pwsh -NoProfile -Command \"Import-Module Pester -Force; Invoke-Pester -Path tests\\\\\" 2>&1$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^& pwsh -NoProfile -Command \\{ Import-Module Pester -Force; Invoke-Pester -Path 'C:\\\\Users\\\\lpensjo\\\\src\\\\perfource-commander-console\\\\tests\\\\' \\} 2>&1$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
